<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_QLBIGSLIDE_TITLE</name>
    <creationDate>2026-02-28</creationDate>
    <author>Mareike Riegel</author>
    <authorEmail>info@ql.de</authorEmail>
    <authorUrl>https://ql.de</authorUrl>
    <copyright>Copyright (C) 2026 Mareike Riegel. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later;</license>
    <version>1.0.0</version>
    <description><![CDATA[MOD_QLBIGSLIDE_XML_DESCRIPTION]]></description>
    <namespace path="src">Hoochicken\Module\Qlbigslide</namespace>
    <files>
        <folder module="mod_qlbigslide">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
        <file>mod_qlbigslide.xml</file>
    </files>

    <media destination="mod_qlbigslide" folder="media">
        <filename>css/mod_qlbigslide.css</filename>
        <filename>js/mod_qlbigslide.js</filename>
    </media>
    <languages>
        <language tag="en-GB">language/en-GB/mod_qlbigslide.ini</language>
        <language tag="en-GB">language/en-GB/mod_qlbigslide.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic" addfieldprefix="Hoochicken\Module\Qlbigslide\Site\Field">
                <field
                        name="moduleclass_sfx"
                        type="text"
                        label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                        description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                />
            </fieldset>
        </fields>
    </config>
</extension>
