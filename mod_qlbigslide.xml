                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="slide1_image" type="media" label="MOD_QLBIGSLIDE_IMAGE_LABEL" description="MOD_QLBIGSLIDE_IMAGE_DESC" directory="images" filter="\.(jpg|jpeg|png|gif|webp)$" />
                <field name="slide1_title" type="text" label="MOD_QLBIGSLIDE_TITLE_LABEL" description="MOD_QLBIGSLIDE_TITLE_DESC" />
                <field name="slide1_text" type="editor" label="MOD_QLBIGSLIDE_TEXT_LABEL" description="MOD_QLBIGSLIDE_TXT_DESC"
