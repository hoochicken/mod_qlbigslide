<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_QLBIGSLIDE_TITLE</name>
    <creationDate>2026-02-28</creationDate>
    <author>Mareike Riegel</author>
    <authorEmail>info@ql.de</authorEmail>
    <authorUrl>https://ql.de</authorUrl>
    <copyright>Copyright (C) 2026 Mareike Riegel. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later;</license>
    <version>1.0.0</version>
    <description><![CDATA[MOD_QLBIGSLIDE_XML_DESCRIPTION]]></description>
    <namespace path="src">Hoochicken\Module\Qlbigslide</namespace>
    <files>
        <folder module="mod_qlbigslide">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
        <file>mod_qlbigslide.xml</file>
    </files>

    <media destination="mod_qlbigslide" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>js</folder>
        <!--filename>css/mod_qlbigslide.css</filename-->
        <filename>js/script.js</filename>
    </media>
    <languages>
        <language tag="en-GB">language/en-GB/mod_qlbigslide.ini</language>
        <language tag="en-GB">language/en-GB/mod_qlbigslide.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="slides" addfieldprefix="Hoochicken\Module\Qlbigslide\Site\Field">
                <field
                        name="slide_1_spacer"
                        type="spacer"
                        label="MOD_QLBIGSLIDE_SPACER_1_LABEL"
                        description="MOD_QLBIGSLIDE_SPACER_1_DESC"
                />
                <field
					name="slide1_display"
					type="radio"
                    class="btn-group btn-group-yesno"
                    layout="joomla.form.field.radio.switcher"
					label="MOD_QLBIGSLIDE_DISPLAY_LABEL"
					description="MOD_QLBIGSLIDE_DISPLAY_DESC"
					default="0"
                    filter="integer"
					>
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                        name="slide1_image"
                        type="media"
                        label="MOD_QLBIGSLIDE_IMAGE_LABEL"
                        description="MOD_QLBIGSLIDE_IMAGE_DESC"
                        directory="images"
                        filter="\.(jpg|jpeg|png|gif|webp)$"
                />
                <field
                        name="slide1_title"
                        type="text"
                        label="MOD_QLBIGSLIDE_TITLE_LABEL"
                        description="MOD_QLBIGSLIDE_TITLE_DESC"
                />
                <field
                        name="slide1_text"
                        type="editor"
                        label="MOD_QLBIGSLIDE_TEXT_LABEL"
                        description="MOD_QLBIGSLIDE_TXT_DESC"
                        height="100"
                        width="100"
                        toolbar_location="top"
                        toolbar_position="top"
                        toolbar_align="left"
                        filter="safehtml"
                />
            </fieldset>
            <fieldset name="basic" addfieldprefix="Hoochicken\Module\Qlbigslide\Site\Field">
                <field
                        name="moduleclass_sfx"
                        type="text"
                        label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                        description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                />
            </fieldset>
        </fields>
    </config>
</extension>
